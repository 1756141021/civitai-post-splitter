# Python
__pycache__/
*.pyc
*.pyo

# Personal upload history & queues
done/
upload/
manifests/
progress/
pixiv/rule_fit/
.tmp/

# Logs (auto-archived, capped to 100/10 days each group)
logs/

# Personal upload history (huge, contains post URLs)
pixiv_validation_cases.json

# User-tunable config (auto-generated with defaults; private once tuned)
config.json
pixiv_censor.json

# X / xhs credentials — NEVER commit. auth_token + ct0 == full account access.
x/cookies*.json
xhs/cookies*.json
# Persistent browser profiles (if they land inside the repo)
.civitai_splitter_x_chrome/
.civitai_splitter_xhs_chrome/

# Anything that looks like a credential dump
*.cookie
*.cookies
*.token
.env
.env.*
secrets.json
credentials.json

# Big Danbooru dictionary (~150MB, fetched via setup script — too big for GitHub)
pixiv/danbooru_jp.json

# Model files (50+ MB, fetched via setup_censor.py)
models/

# Local media dropped beside the tool
*.mp3

# IDE / editor
.vscode/
.idea/
*.swp

# Update check timestamp (per-machine)
.last_update_check
.gstack/
